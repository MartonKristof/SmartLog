<Window x:Class="RaktarGUI.WindowStatistika"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RaktarGUI"
        mc:Ignorable="d"
            Title="Statisztika"
    Height="650"
    Width="1000"
    Background="#F8FAFC">

    <Window.Resources>

        <SolidColorBrush x:Key="BrushPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="BrushSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#0F172A"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="BrushWhite" Color="White"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushWhite}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
        </Style>

    </Window.Resources>

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Fejléc -->

        <Grid Grid.Row="0" Margin="0,0,0,25">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Raktárstatisztika"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushPrimary}"/>

                <TextBlock Text="Vizualizált rendszerkimutatások"
                       FontSize="15"
                       Foreground="{StaticResource BrushSecondary}"
                       Margin="0,5,0,0"/>

            </StackPanel>

            <Border Grid.Column="1"
                Background="{StaticResource BrushWhite}"
                Padding="14,8"
                CornerRadius="10"
                VerticalAlignment="Center">

                <TextBlock Text="Live adatok"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrushAccent}"/>

            </Border>

        </Grid>

        <!-- Felső stat kártyák -->

        <Grid Grid.Row="1" Margin="0,0,0,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                Style="{StaticResource CardBorder}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Összes termék"
                           FontSize="15"
                           Foreground="{StaticResource BrushSecondary}"/>

                    <TextBlock Grid.Row="1"
                           Text="245"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushPrimary}"
                           VerticalAlignment="Bottom"/>

                </Grid>

            </Border>

            <Border Grid.Column="1"
                Style="{StaticResource CardBorder}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Kategóriák"
                           FontSize="15"
                           Foreground="{StaticResource BrushSecondary}"/>

                    <TextBlock Grid.Row="1"
                           Text="12"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushPrimary}"
                           VerticalAlignment="Bottom"/>

                </Grid>

            </Border>

            <Border Grid.Column="2"
                Style="{StaticResource CardBorder}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Készletérték"
                           FontSize="15"
                           Foreground="{StaticResource BrushSecondary}"/>

                    <TextBlock Grid.Row="1"
                           Text="4.2M Ft"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushPrimary}"
                           VerticalAlignment="Bottom"/>

                </Grid>

            </Border>

            <Border Grid.Column="3"
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,20">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Alacsony készlet"
                           FontSize="15"
                           Foreground="{StaticResource BrushSecondary}"/>

                    <TextBlock Grid.Row="1"
                           Text="18"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="#DC2626"
                           VerticalAlignment="Bottom"/>

                </Grid>

            </Border>

        </Grid>

        <!-- Alsó nagy panel -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bal oldal -->

            <Border Grid.Column="0"
                Style="{StaticResource CardBorder}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Top termékek"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushAccent}"
                           Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          IsReadOnly="True">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Termék"
                                            Binding="{Binding Nev}"
                                            Width="*"/>

                            <DataGridTextColumn Header="Eladás"
                                            Binding="{Binding Eladas}"
                                            Width="140"/>

                            <DataGridTextColumn Header="Bevétel"
                                            Binding="{Binding Bevetel}"
                                            Width="160"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- Jobb oldal -->

            <Border Grid.Column="1"
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,20">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Rendszerinformáció"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushAccent}"
                           Margin="0,0,0,20"/>

                    <TextBlock Grid.Row="1"
                           Text="• Utolsó mentés: 2026.05.11"
                           FontSize="15"
                           Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2"
                           Text="• Aktív felhasználó: Admin"
                           FontSize="15"
                           Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3"
                           Text="• Rendszer állapot: Stabil"
                           FontSize="15"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>
